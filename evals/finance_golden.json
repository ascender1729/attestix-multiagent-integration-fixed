    },
    {
      "id": "FIN-005",
      "input": {"ticker": "NVDA"},
      "expected": {
        "must_contain_any": ["Nvidia", "NVDA", "AI"],
        "must_emit_recommendation_in": ["BUY", "SELL", "HOLD"],
        "must_contain_section": ["AI", "semiconductor", "valuation"]
