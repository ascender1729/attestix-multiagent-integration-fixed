        "must_contain_section": ["bullish", "bearish", "risk"],
        "delegation_chain_emits": ["read_trading_algorithms", "debate_investment_strategy", "issue_final_trade_order"]
      },
      "rubric_weight": 1.0,
      "notes": "Reference case from the report scope. All three delegation capabilities must be exercised."
    },
    {
      "id": "FIN-002",
      "input": {"ticker": "AAPL"},
      "expected": {
        "must_contain_any": ["Apple", "AAPL"],
        "must_emit_recommendation_in": ["BUY", "SELL", "HOLD"],
        "must_contain_section": ["earnings", "valuation", "risk"]
      },
      "rubric_weight": 1.0,
      "notes": "Established large-cap. Should not produce hyperbolic recommendations."
    },
    {
      "id": "FIN-003",
      "input": {"ticker": "GME"},
