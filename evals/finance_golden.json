{
  "_notice": "Golden-prompt set for the Finance regulated pipeline. Real ticker symbols, real Groq inference, SYNTHETIC trading algorithm database. No actual trading decision should be made on these outputs.",
  "domain": "finance",
  "entry": "Agents/compliant_main_finance.py",
  "fixtures": [
    {
      "id": "FIN-001",
      "input": {"ticker": "TSLA"},
